DATABASE_URL="mysql://user:password@localhost:3306/reverie"
APP_URL="http://localhost:3000"
SESSION_SECRET="complex_password_at_least_32_characters_long"

# Debug logging (optional)
# Set to "true" to enable debug logging in production builds
# In development, debug logging is always enabled
# DEBUG_LOGGING=true                    # Server-side (API endpoint)
# NEXT_PUBLIC_DEBUG_LOGGING=true        # Client-side (console.log interception)

# LLM Provider: "local" (llama.cpp), "openai", or "gemini"
LLM_PROVIDER="local"
# Provider-specific defaults apply when LLM_BASE_URL / LLM_MODEL_ID are not set:
#   local:  http://127.0.0.1:8080       Qwen/Qwen3-8B-GGUF:Q4_K_M
#   openai: https://api.openai.com      gpt-4o-mini
#   gemini: https://generativelanguage.googleapis.com/v1beta/openai   gemini-2.5-flash
# LLM_BASE_URL="http://127.0.0.1:8080"
# LLM_MODEL_ID="Qwen/Qwen3-8B-GGUF:Q4_K_M"
LLM_TIMEOUT_MS=30000
# LLM_API_KEY=""

# Legacy aliases (still work when LLM_PROVIDER=local and LLM_* not set)
LLAMA_BASE_URL="http://127.0.0.1:8080"
LLAMA_MODEL_ID="Qwen/Qwen3-8B-GGUF:Q4_K_M"

# Knowledge Assistant
KNOWLEDGE_ASSISTANT_MAX_INPUT_CHARS=8000

# Qdrant (vector database for semantic cache)
QDRANT_URL="http://localhost:6333"
QDRANT_COLLECTION="archive_cache"
EMBEDDING_SIMILARITY_THRESHOLD=0.85
